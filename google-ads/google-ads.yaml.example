# Copy this file to google-ads.yaml and fill in your values.
# google-ads.yaml is gitignored — NEVER commit the real file.

# From the Google Ads API Center (Tools & Settings > Setup > API Center)
developer_token: INSERT_DEVELOPER_TOKEN_HERE

# From your Google Cloud OAuth client (see README step 3)
client_id: INSERT_OAUTH_CLIENT_ID_HERE
client_secret: INSERT_OAUTH_CLIENT_SECRET_HERE

# Printed by generate_refresh_token.py
refresh_token: INSERT_REFRESH_TOKEN_HERE

# Only needed if you access the account through a manager (MCC) account:
# the 10-digit manager account ID, digits only.
# login_customer_id: 1234567890

use_proto_plus: True
